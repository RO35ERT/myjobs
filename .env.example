# Copy this file to .env and fill in your own values.
# .env is git-ignored; .env.example is safe to commit.

# Brevo API Key from https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your_brevo_api_key_here

# The verified sender details in Brevo
BREVO_SENDER_NAME=My Job Scraper
BREVO_SENDER_EMAIL=your-verified-sender@example.com

# Backward-compatible alias (used if BREVO_SENDER_EMAIL is not set)
MYJOBS_EMAIL_FROM=

# Where the daily job digest is delivered
MYJOBS_EMAIL_RECIPIENT=your-recipient@example.com

# Telegram Bot Token
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username_here
