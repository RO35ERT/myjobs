# Copy this file to .env and fill in your own values.
# .env is git-ignored; .env.example is safe to commit.

# SMTP server details (Gmail shown as default)
MYJOBS_SMTP_HOST=smtp.gmail.com
MYJOBS_SMTP_PORT=587

# Gmail account used to SEND emails (generate an App Password at myaccount.google.com/apppasswords)
MYJOBS_SMTP_USERNAME=your-sender@gmail.com
MYJOBS_SMTP_PASSWORD=your-gmail-app-password

# The "From" address shown in the email header
MYJOBS_EMAIL_FROM=your-sender@gmail.com

# Where the daily job digest is delivered
MYJOBS_EMAIL_RECIPIENT=your-recipient@example.com
